<?xml version="1.0" encoding="UTF-8"?>
<project name="maven-antrun-" default="main">
  <target name="main">
    <echo message="============================================" />
    <echo message="Build completed! Opening browser..." />
    <echo message="============================================" />
    <sleep seconds="2" />
    <exec executable="cmd" osfamily="windows">
      <arg value="/c" />
      <arg value="start http://localhost:8080/SimpleChatWebSocket/" />
    </exec>
    <exec executable="open" osfamily="mac">
      <arg value="http://localhost:8080/SimpleChatWebSocket/" />
    </exec>
    <exec executable="xdg-open" osfamily="unix">
      <arg value="http://localhost:8080/SimpleChatWebSocket/" />
    </exec>
  </target>
</project>
